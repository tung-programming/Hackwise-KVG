// Prisma schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String?
  avatar              String?
  bio                 String?
  googleId            String?   @unique
  githubId            String?   @unique
  refreshToken        String?
  xp                  Int       @default(0)
  weeklyXp            Int       @default(0)
  level               Int       @default(1)
  streak              Int       @default(0)
  longestStreak       Int       @default(0)
  lastActiveAt        DateTime?
  onboardingCompleted Boolean   @default(false)
  onboardingStep      Int       @default(0)
  onboardingData      Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  interests    Interest[]
  watchHistory WatchHistory[]
  courses      Course[]
  projects     Project[]
  resume       Resume?

  @@map("users")
}

model Interest {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("interests")
}

model WatchHistory {
  id        String   @id @default(uuid())
  userId    String
  title     String
  url       String?
  platform  String
  duration  Int?
  watchedAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
  @@map("watch_history")
}

model Course {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  topic       String
  level       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules Module[]

  @@map("courses")
}

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  resources   String[]
  order       Int
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("modules")
}

model Project {
  id           String    @id @default(uuid())
  userId       String
  title        String
  description  String
  repoUrl      String?
  liveUrl      String?
  technologies String[]
  status       String    @default("in_progress")
  validatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Resume {
  id        String   @id @default(uuid())
  userId    String   @unique
  filename  String
  content   String
  mimeType  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}
